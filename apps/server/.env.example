# SMTP HTTP Proxy Environment Configuration

# Required: CORS origin (for development use *, for production use your domain)
CORS_ORIGIN=http://localhost:3000

# Required: Database URL (required by @stem/env, can be dummy for stateless)
DATABASE_URL=postgres://localhost:5432/dummy

# Required: SMTP Providers Configuration (JSON array)
# Supports multiple providers for failover
# Format: [{"name":"...","host":"...","port":587,"secure":false,"auth":{"user":"...","pass":"..."}}]
SMTP_PROVIDERS=[{"name":"primary","host":"smtp.gmail.com","port":587,"secure":false,"auth":{"user":"your-email@gmail.com","pass":"your-app-password"}},{"name":"fallback","host":"smtp.sendgrid.net","port":465,"secure":true,"auth":{"apiKey":"your-api-key"}}]

# Required: API Keys for authentication (comma-separated)
# Requests must include header: Authorization: Bearer <api-key>
API_KEYS=sk-production-key-1,sk-production-key-2

# Optional: Maximum attachment size (default: 10MB)
MAX_ATTACHMENT_SIZE=10MB

# Optional: Rate limit per minute per API key (default: 60)
RATE_LIMIT_PER_MINUTE=60

# Node environment
NODE_ENV=development
