{
  "name": "stem",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @stem/db db:push",
    "db:studio": "turbo -F @stem/db db:studio",
    "db:generate": "turbo -F @stem/db db:generate",
    "db:migrate": "turbo -F @stem/db db:migrate",
    "db:local": "turbo -F @stem/db db:local",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@stem/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@stem/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.4.4"
  },
  "packageManager": "bun@1.3.11"
}
